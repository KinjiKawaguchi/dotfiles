{
  "editor.wordWrapColumn": 100,
  "editor.lineNumbers": "relative",
  "editor.renderWhitespace": "all",
  "editor.wordWrap": "off",
  "editor.fontLigatures": false,
  "editor.wordSeparators": "./\\()\"'-:,.;<>~!@#$%^&*|+=[]{}`~?　、。「」【】『』（）！？てにをはがのともへでや",
  "editor.guides.indentation": false,
  "editor.guides.bracketPairs": false,
  "files.associations": {
    "*.java": "java",
    "*.tsx": "typescriptreact"
  },
  "files.watcherExclude": {
    "**": true
  },
  "[lua]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false
  },
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "diffEditor.ignoreTrimWhitespace": true
  },
  "python.terminal.activateEnvironment": false,
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 2
  },
  "[tsx]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.tabSize": 2
  },
  "[ts]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.tabSize": 2
  },
  "[java]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "redhat.java"
  },
  "[proto3]": {
    "editor.defaultFormatter": "zxh404.vscode-proto3"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
  },
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "j"
      ],
      "after": [
        "<Esc>"
      ]
    },
    {
      "vim.normalModeKeyBindings": [
        {
          "before": [
            "g",
            "h"
          ],
          "commands": [
            "editor.action.showHover"
          ]
        }
      ]
    }
  ],
  "vim.hlsearch": true,
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.normalModeKeyBindingsNonRecursive": [],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": [
        ";",
        ";"
      ],
      "commands": [
        "editor.action.triggerSuggest"
      ]
    }
  ],
  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#1073cf2d",
    "editor.lineHighlightBorder": "#9fced11f"
  },
  "workbench.iconTheme": "material-icon-theme",
  "redhat.telemetry.enabled": true,
  "diffEditor.wordWrap": "off",
  "remote.SSH.connectTimeout": 300,
  "terminal.integrated.env.windows": {},
  "terminal.integrated.env.osx": {},
  "git.autofetch": true,
  "hediet.vscode-drawio.resizeImages": null,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "never",
  "git.confirmSync": false,
  "githubPullRequests.pullBranch": "never",
  "go.toolsManagement.autoUpdate": true,
  "remote.portsAttributes": {
    "8080": {
      "protocol": "http"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "git.enableCommitSigning": true,
  "git-graph.repository.commits.showSignatureStatus": true,
  "git-graph.repository.sign.commits": true,
  "git-graph.repository.sign.tags": true,
  "githubPullRequests.createOnPublishBranch": "never",
  "workbench.colorTheme": "GitHub Dark",
  "npm.packageManager": "yarn",
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "workbench.editor.empty.hint": "hidden",
  "workbench.productIconTheme": "material-product-icons",
  "javascript.inlayHints.parameterNames.enabled": "all",
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.parameterNames.enabled": "all",
  "jupyter.widgetScriptSources": [
    "jsdelivr.com",
    "unpkg.com"
  ],
  "better-comments.tags": [
    {
      "tag": "NOTE",
      "color": "#000000",
      "backgroundColor": "#87CEEB",
      "bold": true,
    },
    {
      "tag": "TODO",
      "color": "#000000",
      "backgroundColor": "#FF8C00",
      "bold": true,
    }
  ],
  "workbench.editor.enablePreview": false,
  "svg.preview.mode": "svg",
  "files.exclude": {
    ".gitignore": true
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "files.autoSave": "afterDelay",
  "git.replaceTagsWhenPull": true,
  "vsicons.dontShowNewVersionMessage": true,
  "cursorStats.currency": "JPY",
  "accessibility.signals.voiceRecordingStarted": {
    "sound": "off"
  },
  "editor.minimap.enabled": true,
  "update.releaseTrack": "prerelease",
  "coverage-gutters.coverageReportFileName": "coverage.xml",
  // we try to make semantic highlighting look good
  "editor.semanticHighlighting.enabled": true,
  // prevent VSCode from modifying the terminal colors
  "terminal.integrated.minimumContrastRatio": 1,
  // applicable if you use Go, this is an opt-in flag!
  "gopls": {
    "ui.semanticTokens": true,
  },
  "find-it-faster.general.useTerminalInEditor": true,
  "find-it-faster.general.killTerminalAfterUse": true,
  "find-it-faster.general.clearTerminalAfterUse": true,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.languageServer": "None",
  "git.blame.editorDecoration.enabled": true,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "remote.defaultExtensionsIfInstalledLocally": [
    "GitHub.copilot",
    "GitHub.copilot-chat",
    "GitHub.vscode-pull-request-github"
  ],
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.tabSize": 2,
  "editor.aiStats.enabled": true,
  "editor.autoIndentOnPaste": true,
  "window.zoomPerWindow": false,
  "git.repositoryScanMaxDepth": 10,
  "makefile.configureOnOpen": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "window.nativeTabs": true,
  "claudeCode.preferredLocation": "panel",
  "editor.accessibilitySupport": "on",
  "accessibility.signals.lineHasError": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.lineHasWarning": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.lineHasFoldedArea": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.lineHasBreakpoint": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.terminalQuickFix": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.onDebugBreak": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.noInlayHints": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.taskCompleted": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.taskFailed": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.terminalCommandFailed": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.terminalBell": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.notebookCellCompleted": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.notebookCellFailed": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.chatRequestSent": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.codeActionTriggered": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.clear": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.codeActionApplied": {
    "sound": "off"
  },
  "accessibility.signals.terminalCommandSucceeded": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.chatUserActionRequired": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.chatResponseReceived": {
    "sound": "off"
  },
  "accessibility.signals.positionHasError": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.positionHasWarning": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.voiceRecordingStopped": {
    "sound": "off"
  },
  "accessibility.signals.lineHasInlineSuggestion": {
    "sound": "off"
  },
  "accessibility.signals.diffLineDeleted": {
    "sound": "off"
  },
  "accessibility.signals.diffLineInserted": {
    "sound": "off"
  },
  "accessibility.signals.nextEditSuggestion": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.progress": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.chatEditModifiedFile": {
    "sound": "off"
  },
  "accessibility.signals.diffLineModified": {
    "sound": "off"
  },
  "accessibility.signals.editsUndone": {
    "sound": "off",
    "announcement": "auto"
  },
  "accessibility.signals.editsKept": {
    "sound": "off",
    "announcement": "auto"
  },
  "window.zoomLevel": 1,
}